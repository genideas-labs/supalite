# Copy to benchmarks/.env (gitignored) and fill in. Both clients hit the SAME
# Supabase project DB so the comparison is fair.

# Supabase REST endpoint + a key that can READ the table.
# Dashboard -> Project Settings -> API. service_role bypasses RLS (simplest for
# a benchmark); anon works if an RLS select policy exists.
SUPABASE_URL=https://YOUR_REF.supabase.co
SUPABASE_KEY=YOUR_SERVICE_ROLE_OR_ANON_KEY

# Direct Postgres connection to the SAME project.
# Dashboard -> Project Settings -> Database -> Connection string (URI).
# The session pooler (port 5432) or transaction pooler works.
DB_CONNECTION=postgresql://postgres.YOUR_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Which table/columns to query. Pick a real table that has some rows and is
# exposed via the API. Keep the query small so we measure layer overhead, not
# a heavy scan.
BENCH_TABLE=users
BENCH_SELECT=id
BENCH_LIMIT=20

# How many samples. Defaults are fine.
BENCH_ITERATIONS=200
BENCH_WARMUP=20
BENCH_DB_SSL=true
